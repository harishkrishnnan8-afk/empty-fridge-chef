{
    "version": 2,
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "server/index.js": {
            "runtime": "@vercel/node",
            "memory": 1024,
            "maxDuration": 60
        }
    }
}